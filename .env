LLM_GATEWAY_APP_NAME=llm-gateway
LLM_GATEWAY_APP_VERSION=0.0.1
LLM_GATEWAY_ENVIRONMENT=local
LLM_GATEWAY_LOG_LEVEL=INFO

LLM_GATEWAY_OPENAI_PROVIDER=openai
LLM_GATEWAY_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_GATEWAY_OPENAI_MODEL_CHAT=gpt-4.1-mini
LLM_GATEWAY_OPENAI_MODEL_SUMMARIZE=gpt-4.1-mini

LLM_GATEWAY_OPENAI_TIMEOUT_TOTAL_SECONDS=30
LLM_GATEWAY_OPENAI_TIMEOUT_CONNECT_SECONDS=2
LLM_GATEWAY_OPENAI_TIMEOUT_READ_SECONDS=20
LLM_GATEWAY_OPENAI_TIMEOUT_WRITE_SECONDS=10

LLM_GATEWAY_OPENAI_MAX_RETRIES=2